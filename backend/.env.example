# Backend runtime configuration
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8081

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/aharam_dev
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me

# JWT
APP_JWT_SECRET=replace-with-64-byte-secret
APP_JWT_EXPIRATION_MS=86400000

# Mail
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

# Optional seed accounts (dev only)
APP_SEED_DEFAULT_ADMIN_ENABLED=false
APP_SEED_DEFAULT_ADMIN_PASSWORD=
APP_SEED_DEFAULT_STAFF_ENABLED=false
APP_SEED_DEFAULT_STAFF_PASSWORD=

# Notification provider: provider | mock
NOTIFICATION_PROVIDER=provider
